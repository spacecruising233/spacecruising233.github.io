---
import { Image } from "astro:assets";
import path from "node:path";

interface Props {
	id?: string;
	imageSrc: string;
	videoSrc?: string;
	alt?: string;
	position?: string;
	class?: string;
	autoplay?: boolean;
	loop?: boolean;
	muted?: boolean;
	playsinline?: boolean;
	videoOffsetY?: string;
	disableOnMobile?: boolean;
}

const {
	id,
	imageSrc,
	videoSrc,
	alt = "Banner",
	position = "center",
	autoplay = true,
	loop = true,
	muted = true,
	playsinline = true,
	videoOffsetY = "60%",
	disableOnMobile = true,
} = Astro.props;
const className = Astro.props.class;

const isLocalImage = !(
	imageSrc.startsWith("/") ||
	imageSrc.startsWith("http") ||
	imageSrc.startsWith("https") ||
	imageSrc.startsWith("data:")
);

let img: ImageMetadata | undefined;
if (isLocalImage) {
	const files = import.meta.glob<ImageMetadata>("../../**", {
		import: "default",
	});
	let normalizedPath = path
		.normalize(path.join("../../", "/", imageSrc))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (file) {
		img = await file();
	}
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;
const videoStyle = `object-position: center ${videoOffsetY}`;
---

<div id={id} class:list={[className, "banner-video-container overflow-hidden relative"]} data-disable-video-on-mobile={disableOnMobile}>
	<div class="transition absolute inset-0 dark:bg-black/10 bg-opacity-50 pointer-events-none z-10"></div>
	
	<picture class="banner-fallback absolute inset-0 w-full h-full">
		{isLocalImage && img && (
			<Image src={img} alt={alt} class={`${imageClass} banner-image`} style={imageStyle} />
		)}
		{!isLocalImage && (
			<img src={imageSrc} alt={alt} class={`${imageClass} banner-image`} style={imageStyle} />
		)}
	</picture>
	
	{videoSrc && (
		<video
			class="banner-video absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
			style={videoStyle}
			autoplay={autoplay}
			loop={loop}
			muted={muted}
			playsinline={playsinline}
			preload="auto"
			poster={isLocalImage ? undefined : imageSrc}
			data-src={videoSrc}
		>
			<source src={videoSrc} type="video/webm" />
			<source src={videoSrc.replace(/\.webm$/, ".mp4")} type="video/mp4" />
		</video>
	)}
</div>

<script define:vars={{ disableOnMobile }}>
	function isMobileDevice() {
		if (typeof window === 'undefined') return false;
		
		const isCoarsePointer = window.matchMedia('(pointer: coarse)').matches;
		const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
		const isSmallScreen = window.screen.width < 768;
		const isMobileUserAgent = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
		
		return (isCoarsePointer && isSmallScreen) || (isTouchDevice && isSmallScreen) || (isMobileUserAgent && isSmallScreen);
	}

	function initBannerVideo() {
		const containers = document.querySelectorAll('.banner-video-container');
		
		containers.forEach(container => {
			const shouldDisableVideo = container.dataset.disableVideoOnMobile === 'true' && isMobileDevice();
			const video = container.querySelector('.banner-video');
			const fallback = container.querySelector('.banner-fallback');
			
			if (!video) return;
			
			if (shouldDisableVideo) {
				video.remove();
				if (fallback) {
					fallback.classList.remove('opacity-0');
				}
				return;
			}
			
			const videoSrc = video.dataset.src;
			if (!videoSrc) return;
			
			video.addEventListener('loadeddata', () => {
				video.classList.remove('opacity-0');
				video.classList.add('opacity-100');
				if (fallback) {
					fallback.classList.add('opacity-0');
				}
			});
			
			video.addEventListener('error', () => {
				video.classList.add('opacity-0');
				video.classList.remove('opacity-100');
				if (fallback) {
					fallback.classList.remove('opacity-0');
				}
			});
			
			video.addEventListener('stalled', () => {
				if (fallback) {
					fallback.classList.remove('opacity-0');
				}
			});
			
			if (video.readyState >= 3) {
				video.classList.remove('opacity-0');
				video.classList.add('opacity-100');
			}
		});
	}
	
	initBannerVideo();
	
	document.addEventListener('astro:page-load', initBannerVideo);
</script>

<style>
	.banner-video-container {
		position: relative;
	}
	
	.banner-video {
		z-index: 5;
	}
	
	.banner-fallback {
		z-index: 1;
		transition: opacity 0.5s ease;
	}
	
	.banner-image {
		width: 100%;
		height: 100%;
	}
</style>
